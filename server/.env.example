# ── InsightBI backend environment ───────────────────────────────
# Copy to .env for local dev. On Render these are set as env vars.

# SQLite database file (relative to src/prisma/schema.prisma)
DATABASE_URL="file:./dev.db"

# Auth
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Uploads
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Optional — Redis cache (server runs fine without it)
# REDIS_URL="redis://localhost:6379"
